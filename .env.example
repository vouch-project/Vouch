# Supabase (server-side — used by apps/api)
SUPABASE_URL=http://localhost:54321
SUPABASE_SECRET_KEY=your-secret-key

# Supabase (client-exposed — used by apps/web, PUBLIC_ prefix required by SvelteKit)
PUBLIC_SUPABASE_URL=http://localhost:54321
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Reown / Web3Modal (client-exposed — used by apps/web)
PUBLIC_REOWN_PROJECT_ID=your-reown-project-id

# Database (direct connection — used by API/migrations)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
