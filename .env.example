# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Blockchain
RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR-API-KEY
RPC_URL_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY
RPC_URL_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY
PRIVATE_KEY=your-private-key-for-liquidation-bot

# Smart Contract Addresses
LENDING_POOL_ADDRESS=0x...
CREDIT_SCORE_ORACLE_ADDRESS=0x...

# API Configuration
CORE_API_PORT=3001
ML_API_PORT=8000
FRONTEND_PORT=5173

# External APIs
ETHERSCAN_API_KEY=your-etherscan-api-key
POLYGONSCAN_API_KEY=your-polygonscan-api-key

# ML Service
MODEL_PATH=/app/models
FEATURE_EXTRACTORS=transaction_count,avg_balance,loan_history

# JWT Secret
JWT_SECRET=your-jwt-secret-change-in-production

# Node Environment
NODE_ENV=development
